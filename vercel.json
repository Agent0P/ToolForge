{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/tool/(.*)", "destination": "/index.html" },
    { "source": "/faq",      "destination": "/index.html" },
    { "source": "/terms",    "destination": "/index.html" },
    { "source": "/refund",   "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/keep-alive",
      "schedule": "0 9 * * *"
    }
  ]
}
